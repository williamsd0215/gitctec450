def evaluate_fgsm(model, data_loader, epsilon):

    model.eval()

    correct_predictions = 0
    total_images = 0

    for images, labels in data_loader:

        images, labels = images.to(device), labels.to(device)

        images.requires_grad = True

        outputs = model(images)

        loss = loss_function(outputs, labels)

        model.zero_grad()

        loss.backward()

        image_gradient = images.grad.data

        attacked_images = fgsm_attack(
            images,
            epsilon,
            image_gradient
        )

        attacked_outputs = model(attacked_images)

        predictions = attacked_outputs.argmax(dim=1)

        correct_predictions += (
            predictions == labels
        ).sum().item()

        total_images += labels.size(0)

    accuracy = correct_predictions / total_images

    print(
        f"FGSM Attack Accuracy (epsilon={epsilon}): "
        f"{accuracy * 100:.2f}%"
    )

    return accuracy
